#!/bin/bash
set -euo pipefail
trap 'echo "EXIT detected with exit status $?"' EXIT

# helpers
function echo_ok() { echo -e '\033[1;32m'"$1"'\033[0m'; }
function echo_warn() { echo -e '\033[1;33m'"$1"'\033[0m'; }
function echo_error() { echo -e '\033[1;31mERROR: '"$1"'\033[0m'; }

system_type=$(uname -s)

declare -a rust_utils=(
  "eza"
  "bat"
  "starship"
  "cargo-update"
  "cargo-cache"
  "fd-find"
  "git-delta"
  "ripgrep"
  "zoxide"
  "sd"
  "topgrade"
  "du-dust"
  "stylua"
)

if command -v yum >/dev/null 2>&1; then
  sudo yum install -y openssl openssl-devel
elif command -v apt-get >/dev/null 2>&1; then
  sudo apt-get install -y openssl libssl-dev
fi

install_brew() {
  XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"

  if ! command -v brew >/dev/null 2>&1; then
    echo_warn "Installing Homebrew"
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/master/install.sh)"
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
  fi

  echo_warn "Installing tools via brew"

  brew tap arl/arl

  brew install cmake \
               gitmux \
               jesseduffield/lazygit/lazygit \
               awscli \
               curl \
               wget \
               fzf \
               git \
               htop \
               neovim \
               tmux \
               less \
               restic \
               btop \
               npm \
               sesh

  if [ "$system_type" = "Darwin" ]; then
    echo_warn "Installing MAC tools via brew"
    brew tap "homebrew/cask-fonts"

    brew install koekeishiya/formulae/skhd \
                 unison \
                 python3

    brew install --cask stats alacritty unnaturalscrollwheels font-jetbrains-mono-nerd-font koekeishiya/formulae/yabai raycast font-maple-mono-normal-nf

    skhd --start-service
  fi
}

install_tpm() {
  local tpm_dir="$HOME/.tmux/plugins/tpm"
  if [ -d "$tpm_dir" ]; then
    echo_ok "TPM already installed, pulling latest"
    git -C "$tpm_dir" pull
  else
    echo_warn "Installing TPM"
    git clone https://github.com/tmux-plugins/tpm "$tpm_dir"
  fi
}

install_font() {
  local font_dir="$HOME/nerd-fonts"
  if [ -d "$font_dir" ]; then
    echo_ok "nerd-fonts repo already exists, skipping"
  else
    cd "$HOME"
    git clone --filter=blob:none --sparse git@github.com:ryanoasis/nerd-fonts
    cd nerd-fonts
    git sparse-checkout add patched-fonts/JetBrainsMono install.sh
    ./install.sh JetBrainsMono
  fi
}

install_fzf() {
  yes | "$(brew --prefix)/opt/fzf/install" || true
  local fzf_git="$HOME/fzf-git.sh"
  if [ ! -f "$fzf_git" ]; then
    wget -O "$fzf_git" https://raw.githubusercontent.com/junegunn/fzf-git.sh/main/fzf-git.sh
  fi
}

install_cargo() {
  if command -v cargo >/dev/null 2>&1; then
    echo_ok "Cargo already installed, skipping"
  else
    curl --proto '=https' --tlsv1.3 -sSf https://sh.rustup.rs | sh -s -- -y
    source "$HOME/.cargo/env"
  fi
  rustup toolchain install nightly
}

install_nvim() {
  echo_warn "Installing Neovim from source"
  local nvim_dir="$HOME/neovim"
  if [ -d "$nvim_dir" ]; then
    git -C "$nvim_dir" pull
  else
    git clone git@github.com:neovim/neovim.git "$nvim_dir"
  fi
  cd "$nvim_dir"
  make CMAKE_BUILD_TYPE=RelWithDebInfo
  sudo make install
}

install_cmake() {
  cd "$HOME"
  local cmake_script="cmake-3.25.2-linux-x86_64.sh"
  if [ ! -f "$cmake_script" ]; then
    wget "https://github.com/Kitware/CMake/releases/download/v3.25.2/$cmake_script"
    chmod u+x "$cmake_script"
  fi
  ./"$cmake_script"
}

install_nvm() {
  if [ -d "$HOME/.nvm" ]; then
    echo_ok "NVM already installed, skipping"
  else
    curl -o- --tlsv1.2 https://raw.githubusercontent.com/nvm-sh/nvm/v0.39.3/install.sh | bash
  fi
}

configure_rust() {
  declare -a rustup_components=(
    "rust-docs"
    "clippy"
    "llvm-tools"
    "rust-analyzer"
    "rustfmt"
    "cargo"
    "rust-std"
  )

  for var in "${rustup_components[@]}"; do
    rustup component add "$var"
    rustup component add --toolchain nightly "$var"
  done

  for var in "${rust_utils[@]}"; do
    cargo install "$var"
  done

  mkdir -p "$HOME/.config/topgrade"
  ln -sf "$HOME/.config/topgrade/topgrade_linux.toml" "$HOME/.config/topgrade/topgrade.toml"
  if [ "$system_type" = "Darwin" ]; then
    ln -sf "$HOME/.config/topgrade/topgrade_darwin.toml" "$HOME/.config/topgrade/topgrade.toml"
  fi
}

if [ "$system_type" = "Darwin" ]; then
  rust_utils+=("unison-fsmonitor")

  sudo sysctl kern.maxfiles=1310720 kern.maxfilesperproc=65536

  defaults write com.apple.dock "mru-spaces" -bool "false" && killall Dock
  defaults write com.apple.dock autohide -bool true
  defaults delete com.apple.dock persistent-apps || true
  defaults delete com.apple.dock persistent-others || true

  defaults write com.apple.symbolichotkeys AppleSymbolicHotKeys -dict-add 79 "{enabled = 0; value = { parameters = (65535, 123, 8650752); type = standard;};}"
  defaults write com.apple.symbolichotkeys AppleSymbolicHotKeys -dict-add 80 "{enabled = 0; value = { parameters = (65535, 123, 8781824); type = standard;};}"
  defaults write com.apple.symbolichotkeys AppleSymbolicHotKeys -dict-add 81 "{enabled = 0; value = { parameters = (65535, 124, 8650752); type = standard;};}"
  defaults write com.apple.symbolichotkeys AppleSymbolicHotKeys -dict-add 82 "{enabled = 0; value = { parameters = (65535, 124, 8781824); type = standard;};}"
  defaults write com.apple.dock no-bouncing -bool TRUE
  killall Dock
fi

# install_cmake
# install_nvim
# install_font

install_brew
install_fzf
install_cargo
configure_rust
install_nvm
install_tpm
